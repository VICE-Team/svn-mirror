lib_LTLIBRARIES = \
src/libresidfp.la


#=========================================================
# libresidfp
src_libresidfp_la_SOURCES = \
src/array.h \
src/Dac.cpp \
src/Dac.h \
src/EnvelopeGenerator.cpp \
src/EnvelopeGenerator.h \
src/ExternalFilter.cpp \
src/ExternalFilter.h \
src/Filter.cpp \
src/Filter.h \
src/Filter6581.cpp \
src/Filter6581.h \
src/Filter8580.cpp \
src/Filter8580.h \
src/FilterModelConfig.cpp \
src/FilterModelConfig.h \
src/FilterModelConfig6581.cpp \
src/FilterModelConfig6581.h \
src/FilterModelConfig8580.cpp \
src/FilterModelConfig8580.h \
src/Integrator.h \
src/Integrator6581.cpp \
src/Integrator6581.h \
src/Integrator8580.cpp \
src/Integrator8580.h \
src/OpAmp.cpp \
src/OpAmp.h \
src/SID.cpp \
src/SID.h \
src/Spline.cpp \
src/Spline.h \
src/Voice.h \
src/WaveformCalculator.cpp \
src/WaveformCalculator.h \
src/WaveformGenerator.cpp \
src/WaveformGenerator.h \
src/resample/Limiter.h \
src/resample/Resampler.h \
src/resample/PassThrough.h \
src/resample/ZeroOrderResampler.h \
src/resample/SincResampler.cpp \
src/resample/SincResampler.h \
src/resample/TwoPassSincResampler.h \
src/version.cc \
src/residfp/residfp.cpp

src_libresidfp_la_LDFLAGS = -version-info $(LIBRESIDFPVERSION) $(W32_LDFLAGS)
src_libresidfp_ladir = $(includedir)/residfp
src_libresidfp_la_HEADERS = \
src/residfp/residfp.h \
src/residfp/residfp_defs.h

nodist_src_libresidfp_la_HEADERS = \
src/residfp/sidversion.h

src_libresidfp_la_CPPFLAGS = $(AM_CPPFLAGS) @RESIDFP_CXXFLAGS@
@ENABLE_TEST_TRUE@src_resample_test_SOURCES = \
@ENABLE_TEST_TRUE@src/resample/test.cpp \
@ENABLE_TEST_TRUE@src/resample/SincResampler.cpp


#=========================================================
pkgconfigdir = $(libdir)/pkgconfig
pkgconfig_DATA = libresidfp.pc
all: all-recursive

.SUFFIXES:
.SUFFIXES: .cc .cpp .lo .o .obj
am--refresh: Makefile
	@:
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am  $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      echo ' cd $(srcdir) && $(AUTOMAKE) --foreign'; \
	      $(am__cd) $(srcdir) && $(AUTOMAKE) --foreign \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --foreign Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    echo ' $(SHELL) ./config.status'; \
	    $(SHELL) ./config.status;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__maybe_remake_depfiles);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	$(SHELL) ./config.status --recheck

$(top_srcdir)/configure:  $(am__configure_deps)
	$(am__cd) $(srcdir) && $(AUTOCONF)
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	$(am__cd) $(srcdir) && $(ACLOCAL) $(ACLOCAL_AMFLAGS)
$(am__aclocal_m4_deps):
@HAVE_DOXYGEN_TRUE@Doxyfile: $(top_builddir)/config.status $(srcdir)/Doxyfile.in
@HAVE_DOXYGEN_TRUE@	cd $(top_builddir) && $(SHELL) ./config.status $@
libresidfp.pc: $(top_builddir)/config.status $(srcdir)/libresidfp.pc.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
src/siddefs-fp.h: $(top_builddir)/config.status $(top_srcdir)/src/siddefs-fp.h.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
src/residfp/sidversion.h: $(top_builddir)/config.status $(top_srcdir)/src/residfp/sidversion.h.in
	cd $(top_builddir) && $(SHELL) ./config.status $@

clean-noinstPROGRAMS:
	$(am__rm_f) $(noinst_PROGRAMS)
	test -z "$(EXEEXT)" || $(am__rm_f) $(noinst_PROGRAMS:$(EXEEXT)=)

install-libLTLIBRARIES: $(lib_LTLIBRARIES)
	@$(NORMAL_INSTALL)
	@list='$(lib_LTLIBRARIES)'; test -n "$(libdir)" || list=; \
	list2=; for p in $$list; do \
	  if test -f $$p; then \
	    list2="$$list2 $$p"; \
	  else :; fi; \
	done; \
	test -z "$$list2" || { \
	  echo " $(MKDIR_P) '$(DESTDIR)$(libdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(libdir)" || exit 1; \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 '$(DESTDIR)$(libdir)'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 "$(DESTDIR)$(libdir)"; \
	}

uninstall-libLTLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@list='$(lib_LTLIBRARIES)'; test -n "$(libdir)" || list=; \
	for p in $$list; do \
	  $(am__strip_dir) \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f '$(DESTDIR)$(libdir)/$$f'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f "$(DESTDIR)$(libdir)/$$f"; \
	done

clean-libLTLIBRARIES:
	-$(am__rm_f) $(lib_LTLIBRARIES)
	@list='$(lib_LTLIBRARIES)'; \
	locs=`for p in $$list; do echo $$p; done | \
	      sed 's|^[^/]*$$|.|; s|/[^/]*$$||; s|$$|/so_locations|' | \
	      sort -u`; \
	echo rm -f $${locs}; \
	$(am__rm_f) $${locs}
src/$(am__dirstamp):
	@$(MKDIR_P) src
	@: >>src/$(am__dirstamp)
src/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) src/$(DEPDIR)
	@: >>src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Dac.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-EnvelopeGenerator.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-ExternalFilter.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Filter.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Filter6581.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Filter8580.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-FilterModelConfig.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-FilterModelConfig6581.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-FilterModelConfig8580.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Integrator6581.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Integrator8580.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-OpAmp.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-SID.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-Spline.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-WaveformCalculator.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-WaveformGenerator.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/resample/$(am__dirstamp):
	@$(MKDIR_P) src/resample
	@: >>src/resample/$(am__dirstamp)
src/resample/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) src/resample/$(DEPDIR)
	@: >>src/resample/$(DEPDIR)/$(am__dirstamp)
src/resample/libresidfp_la-SincResampler.lo:  \
	src/resample/$(am__dirstamp) \
	src/resample/$(DEPDIR)/$(am__dirstamp)
src/libresidfp_la-version.lo: src/$(am__dirstamp) \
	src/$(DEPDIR)/$(am__dirstamp)
src/residfp/$(am__dirstamp):
	@$(MKDIR_P) src/residfp
	@: >>src/residfp/$(am__dirstamp)
src/residfp/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) src/residfp/$(DEPDIR)
	@: >>src/residfp/$(DEPDIR)/$(am__dirstamp)
src/residfp/libresidfp_la-residfp.lo: src/residfp/$(am__dirstamp) \
	src/residfp/$(DEPDIR)/$(am__dirstamp)

src/libresidfp.la: $(src_libresidfp_la_OBJECTS) $(src_libresidfp_la_DEPENDENCIES) $(EXTRA_src_libresidfp_la_DEPENDENCIES) src/$(am__dirstamp)
	$(AM_V_CXXLD)$(src_libresidfp_la_LINK) -rpath $(libdir) $(src_libresidfp_la_OBJECTS) $(src_libresidfp_la_LIBADD) $(LIBS)
src/resample/test.$(OBJEXT): src/resample/$(am__dirstamp) \
	src/resample/$(DEPDIR)/$(am__dirstamp)
src/resample/SincResampler.$(OBJEXT): src/resample/$(am__dirstamp) \
	src/resample/$(DEPDIR)/$(am__dirstamp)

src/resample/test$(EXEEXT): $(src_resample_test_OBJECTS) $(src_resample_test_DEPENDENCIES) $(EXTRA_src_resample_test_DEPENDENCIES) src/resample/$(am__dirstamp)
	@rm -f src/resample/test$(EXEEXT)
	$(AM_V_CXXLD)$(CXXLINK) $(src_resample_test_OBJECTS) $(src_resample_test_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f src/*.$(OBJEXT)
	-rm -f src/*.lo
	-rm -f src/resample/*.$(OBJEXT)
	-rm -f src/resample/*.lo
	-rm -f src/residfp/*.$(OBJEXT)
	-rm -f src/residfp/*.lo

distclean-compile:
	-rm -f *.tab.c

